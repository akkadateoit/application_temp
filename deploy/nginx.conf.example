# Example Nginx reverse-proxy config for the NBU application system.
# Copy to /etc/nginx/sites-available/nbu-application, edit server_name,
# then: ln -s /etc/nginx/sites-available/nbu-application /etc/nginx/sites-enabled/
# and: nginx -t && systemctl reload nginx

server {
    listen 80;
    server_name apply.northbkk.ac.th;

    client_max_body_size 15m;          # allow room for two ~5MB image uploads + form fields

    location / {
        proxy_pass http://127.0.0.1:3400;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# After confirming the site works over HTTP, obtain a TLS certificate, e.g.:
#   sudo certbot --nginx -d apply.northbkk.ac.th
# certbot will rewrite this file to add a 443 server block automatically.
